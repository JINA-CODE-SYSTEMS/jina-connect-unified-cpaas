# =============================================================================
# Jina Connect — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# --- Core Django ---
DEBUG=False
SECRET_KEY=change-me-in-production
FIELD_ENCRYPTION_KEY=replace-with-a-valid-fernet-key

# --- Database ---
DB_NAME=jc6
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost

# --- URLs ---
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
SITE_URL=http://localhost:8000

# --- JWT ---
ACCESS_TOKEN_LIFETIME=90

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Jina Connect <noreply@jinaconnect.com>

# --- Storage (local | s3 | gcs) ---
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
GS_BUCKET_NAME=
GS_PROJECT_ID=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_URL=https://api.razorpay.com/v1/

# --- WhatsApp ---
WHATSAPP_ENABLED=False
WHATSAPP_API_TOKEN=

# --- Meta / Webhooks ---
META_PERM_TOKEN=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# --- Gupshup ---
GUPSHUP_BASE_URL=
GUPSHUP_EMAIL=
GUPSHUP_PASSWORD=

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# --- ChatFlow node-type registry ---
# True (dev): unknown node types in flow_data log a warning at save.
# False (prod): unknown types are silently ignored once registry is complete.
WARN_ON_UNKNOWN_NODE_TYPES=True

# --- WebSocket ---
WEBSOCKET_ACCEPT_ALL=True
WEBSOCKET_TOKEN_EXPIRY=3600

# --- Broadcast ---
BROADCAST_BATCH_SIZE=50
BROADCAST_BATCH_DELAY=5
BROADCAST_MAX_RETRIES=3
BROADCAST_CLEANUP_DAYS=30
BROADCAST_CANCELLATION_TIME_LIMIT_IN_MINUTES=0.05

# --- Currency ---
OPEN_EXCHANGE_RATES_APP_ID=

# --- Deep Linking ---
APPLE_TEAM_ID=XXXXXXXXXX
IOS_BUNDLE_ID=com.jinacode.jinaconnect
ANDROID_PACKAGE_NAME=com.jinacode.jinaconnect
MOBILE_APP_SCHEME=jinaconnect
