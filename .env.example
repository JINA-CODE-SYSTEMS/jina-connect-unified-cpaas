# =============================================================================
# Jina Connect — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# --- Core Django ---
DEBUG=False
SECRET_KEY=change-me-in-production
FIELD_ENCRYPTION_KEY=replace-with-a-valid-fernet-key

# --- Database ---
DB_NAME=jc6
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost

# --- URLs ---
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
SITE_URL=http://localhost:8000

# --- JWT ---
ACCESS_TOKEN_LIFETIME=90

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Jina Connect <noreply@jinaconnect.com>

# --- Storage (local | s3 | gcs) ---
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
GS_BUCKET_NAME=
GS_PROJECT_ID=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_URL=https://api.razorpay.com/v1/

# --- WhatsApp ---
WHATSAPP_ENABLED=False
WHATSAPP_API_TOKEN=

# --- Meta / Webhooks ---
META_PERM_TOKEN=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# --- Gupshup ---
GUPSHUP_BASE_URL=
GUPSHUP_EMAIL=
GUPSHUP_PASSWORD=

# --- Redis / Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# --- Voice channel ---
# Settings below are split into three groups by what needs them:
#   (a) HTTP voice + SIP — recording storage / call duration / transcription
#   (b) SIP only         — Asterisk ARI + PJSIP drop dir
#   (c) Both             — none (HTTP voice creds live on VoiceProviderConfig)
# HTTP voice providers (Twilio / Plivo / Vonage / Telnyx / Exotel) don't
# need any env var — their credentials are stored encrypted on the
# VoiceProviderConfig row created via the REST or admin UI.

# (a) Recording storage. Dedicated S3-compatible bucket for voice
# recordings; falls back to AWS_STORAGE_BUCKET_NAME if unset, but
# production should use a dedicated bucket so retention lifecycle
# rules don't collide with the media bucket. Required when
# VoiceProviderConfig.recording_enabled = True on any config.
VOICE_RECORDING_STORAGE_BUCKET=
# Hard ceiling on a single call's lifetime. Drives the IVR session TTL
# (this value + 60s) so a stuck call eventually expires from Redis.
VOICE_MAX_CALL_DURATION_SECONDS=3600

# (a) Transcription backend. Leave blank to disable. Allowed values:
#   "deepgram"        — Deepgram Listen REST endpoint (needs DEEPGRAM_API_KEY)
#   "whisper"         — OpenAI Whisper (needs OPENAI_API_KEY)
#   "provider_native" — defer to whatever the recording webhook surfaces
#                        (e.g. Twilio Transcription); no API key required
VOICE_TRANSCRIPTION_PROVIDER=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# (b) Asterisk — only needed for SIP voice; ignore for HTTP-only setups.
# Bring up the Asterisk container via:  docker-compose --profile sip up
ASTERISK_ARI_URL=http://asterisk:8088
ASTERISK_ARI_USER=
ASTERISK_ARI_PASSWORD=
ASTERISK_ARI_APP_NAME=jina-voice
# Directory the app drops rendered PJSIP fragments into; Asterisk
# mounts the same volume and ``pjsip reload``s on changes. Empty →
# falls back to <project>/asterisk-config/pjsip.d.
ASTERISK_PJSIP_DROP_DIR=

# --- ChatFlow node-type registry ---
# True (dev): unknown node types in flow_data log a warning at save.
# False (prod): unknown types are silently ignored once registry is complete.
WARN_ON_UNKNOWN_NODE_TYPES=True

# --- WebSocket ---
WEBSOCKET_ACCEPT_ALL=True
WEBSOCKET_TOKEN_EXPIRY=3600

# --- Broadcast ---
BROADCAST_BATCH_SIZE=50
BROADCAST_BATCH_DELAY=5
BROADCAST_MAX_RETRIES=3
BROADCAST_CLEANUP_DAYS=30
BROADCAST_CANCELLATION_TIME_LIMIT_IN_MINUTES=0.05

# --- Currency ---
OPEN_EXCHANGE_RATES_APP_ID=

# --- Deep Linking ---
APPLE_TEAM_ID=XXXXXXXXXX
IOS_BUNDLE_ID=com.jinacode.jinaconnect
ANDROID_PACKAGE_NAME=com.jinacode.jinaconnect
MOBILE_APP_SCHEME=jinaconnect
